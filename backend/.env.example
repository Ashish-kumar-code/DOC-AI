# ==================== DOC AI .env.example ====================

SECRET_KEY=your-very-long-random-secret-key-at-least-64-characters-here-2026
JWT_SECRET_KEY=your-super-secret-jwt-key-different-from-secret-key-2026

# === Database ===
# For development (recommended):
SQLALCHEMY_DATABASE_URI=sqlite:///doc_ai.db
# For production (example):
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://user:password@localhost/doc_ai

SQLALCHEMY_TRACK_MODIFICATIONS=False

# === Uploads & Files ===
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=8388608

# === Google Places API (Required for nearby doctors & medical stores) ===
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# === Logging ===
LOG_LEVEL=DEBUG
LOG_DIR=logs

# === Rate Limiting ===
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100/60

# === Input Validation Rules ===
MAX_STRING_LENGTH=1000
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=128

# === Optional (for future production) ===
FLASK_ENV=development
FLASK_DEBUG=True