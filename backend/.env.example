# ==================== DOC AI .env.example ====================

# === SECURITY (CHANGE THESE IN PRODUCTION!) ===
# Generate strong keys using: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-this-to-a-very-long-random-string-at-least-64-characters-2026
JWT_SECRET_KEY=another-different-super-secret-jwt-key-here-2026

# === Database ===
# Development (SQLite - easy for local)
SQLALCHEMY_DATABASE_URI=sqlite:///doc_ai.db

# Production (PostgreSQL - recommended for Render/Vercel)
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://username:password@hostname:5432/doc_ai

SQLALCHEMY_TRACK_MODIFICATIONS=False

# === File Uploads ===
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216        # 16MB (increase if needed for medical images)

# === Google Places API (Optional but recommended for Nearby feature) ===
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# === Logging ===
LOG_LEVEL=INFO
LOG_DIR=logs

# === Rate Limiting ===
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100/60

# === Input Validation Rules ===
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=128
MAX_STRING_LENGTH=1000

# === Model Paths ===
TEXT_MODEL_PATH=app/ml/text_model.joblib
IMAGE_MODEL_PATH=app/ml/image_model.h5